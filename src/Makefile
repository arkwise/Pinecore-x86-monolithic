CC = i686-elf-gcc
AS = nasm
LD = i686-elf-ld

CFLAGS_COMMON = -march=i386 -ffreestanding -nostdlib -O2 -g -Wall -Wextra -Iinclude \
                -fstack-protector-strong -mstack-protector-guard=global
ASFLAGS = -f elf32

# Source files (shared between both kernel modes)
ASM_SRC = boot/boot.asm boot/isr_stubs.asm libc/setjmp.asm
C_SRC   = kernel/main.c kernel/idt.c kernel/pic.c kernel/pit.c \
          kernel/serial.c kernel/vga.c kernel/pmm.c kernel/vmm.c \
          kernel/heap.c kernel/keyboard.c kernel/mouse.c \
          kernel/ata.c kernel/fat.c kernel/mount.c kernel/dos.c \
          kernel/tss.c kernel/v86.c kernel/comload.c kernel/exeload.c kernel/fdc.c kernel/rtc.c \
          kernel/sched.c kernel/vt.c kernel/shell.c kernel/vbe.c kernel/dpmi.c kernel/vcpi.c \
          kernel/config.c kernel/setup.c kernel/build_info.c kernel/v86_kbd.c \
          kernel/panic.c kernel/pci.c kernel/module.c kernel/kexports.c kernel/klog.c \
          kernel/net.c kernel/dma.c kernel/irq.c kernel/int13.c kernel/port_io.c \
          kernel/stack_chk.c kernel/hwinfo.c \
          libc/string.c

# Object files — separate build dirs for each mode
DOS_OBJ_DIR  = build/dos
PURE_OBJ_DIR = build/pure

DOS_ASM_OBJ  = $(ASM_SRC:%.asm=$(DOS_OBJ_DIR)/%.o)
DOS_C_OBJ    = $(C_SRC:%.c=$(DOS_OBJ_DIR)/%.o)
DOS_OBJ      = $(DOS_ASM_OBJ) $(DOS_C_OBJ)

PURE_ASM_OBJ = $(ASM_SRC:%.asm=$(PURE_OBJ_DIR)/%.o)
PURE_C_OBJ   = $(C_SRC:%.c=$(PURE_OBJ_DIR)/%.o)
PURE_OBJ     = $(PURE_ASM_OBJ) $(PURE_C_OBJ)

CFLAGS_DOS  = $(CFLAGS_COMMON) -DKERNEL_MODE_DOS
CFLAGS_PURE = $(CFLAGS_COMMON) -DKERNEL_MODE_PURE

# Output binaries
KERNEL_DOS  = kernel.dos.bin
KERNEL_PURE = kernel.pure.bin

# ================================================================
# Build stamp — kernel/build_info.c regenerated on every `make` so the
# kernel banner reflects the actual build that produced the binary.
# Without this, __DATE__/__TIME__ in shell.c stay stale across
# incremental builds where shell.o is not recompiled.
# ================================================================
.PHONY: FORCE
kernel/build_info.c: FORCE
	@printf '/* AUTO-GENERATED by Makefile — do not edit, do not commit. */\n' > $@
	@printf 'const char         pinecore_build_date[] = "%s";\n' "$$(date '+%Y-%m-%d')" >> $@
	@printf 'const char         pinecore_build_time[] = "%s";\n' "$$(date '+%H:%M:%S')" >> $@
	@printf 'const char         pinecore_build_git[]  = "%s%s";\n' "$$(git -C .. rev-parse --short HEAD 2>/dev/null || echo no-git)" "$$(git -C .. diff --quiet HEAD 2>/dev/null || echo -dirty)" >> $@
	@printf 'const unsigned long pinecore_build_seq    = %s;\n' "$$(date '+%s')" >> $@

# ================================================================
# Default: build both kernels
# ================================================================
all: $(KERNEL_DOS) $(KERNEL_PURE)

# ================================================================
# DOS kernel
# ================================================================
$(KERNEL_DOS): $(DOS_OBJ) linker.ld
	$(LD) -T linker.ld -o $(KERNEL_DOS) $(DOS_OBJ)
	@echo "DOS kernel build OK"

$(DOS_OBJ_DIR)/%.o: %.asm | $(DOS_OBJ_DIR)
	@mkdir -p $(dir $@)
	$(AS) $(ASFLAGS) $< -o $@

$(DOS_OBJ_DIR)/%.o: %.c | $(DOS_OBJ_DIR)
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS_DOS) -c $< -o $@

# ================================================================
# Pure kernel
# ================================================================
$(KERNEL_PURE): $(PURE_OBJ) linker.ld
	$(LD) -T linker.ld -o $(KERNEL_PURE) $(PURE_OBJ)
	@echo "Pure kernel build OK"

$(PURE_OBJ_DIR)/%.o: %.asm | $(PURE_OBJ_DIR)
	@mkdir -p $(dir $@)
	$(AS) $(ASFLAGS) $< -o $@

$(PURE_OBJ_DIR)/%.o: %.c | $(PURE_OBJ_DIR)
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS_PURE) -c $< -o $@

# Build directories
$(DOS_OBJ_DIR) $(PURE_OBJ_DIR):
	mkdir -p $@/boot $@/kernel $@/libc

# ================================================================
# Flat binaries + disk image updates
# ================================================================
flat: all
	@echo "=== Creating flat binaries ==="
	i686-elf-objcopy -O binary $(KERNEL_DOS) kernel.dos.flat
	i686-elf-objcopy -O binary $(KERNEL_PURE) kernel.pure.flat
	nasm -f bin -o boot/pine.com boot/pine.asm
	@echo "=== Updating DOS disk images ==="
	mcopy -i pinecore-dist.img -o kernel.dos.flat ::/KERNEL.BIN
	mcopy -i pinecore-dist.img -o boot/pine.com ::/PINE.COM
	mcopy -i pinecore-hdd.img -o kernel.dos.flat ::/KERNEL.BIN
	@echo "=== Updating Pure disk images ==="
	mcopy -i pinecore-pure.img -o kernel.pure.flat ::/KERNEL.BIN
	mcopy -i pinecore-pure.img -o boot/pine.com ::/PINE.COM
	mcopy -i pinecore-pure-hdd.img -o kernel.pure.flat ::/KERNEL.BIN
	@echo "=== Updating DOOM disk ==="
	mcopy -i pinecore-doom.img -o kernel.pure.flat ::/KERNEL.BIN
	@ls -la kernel.dos.flat kernel.pure.flat
	@echo "=== All images updated ==="

# Legacy 'make flat' compatibility — also update old image names
flat-compat: flat
	cp kernel.dos.flat kernel.flat
	-mcopy -i pinecore-dist.img -o kernel.dos.flat ::/KERNEL.BIN 2>/dev/null
	-mcopy -i pinecore-dist.img -o boot/pine.com ::/PINE.COM 2>/dev/null
	-mcopy -i pinecore-hdd.img -o kernel.dos.flat ::/KERNEL.BIN 2>/dev/null

# ================================================================
# Run targets
# ================================================================
run-dos: flat
	qemu-system-i386 -drive file=pinecore-dist.img,format=raw,if=floppy,index=0 \
		-drive file=pinecore-hdd.img,format=raw,if=ide,index=0 \
		-serial file:/tmp/pinecore-serial.log -display cocoa -m 32 -boot a

run-pure: flat
	qemu-system-i386 -kernel $(KERNEL_PURE) \
		-drive file=pinecore-pure-hdd.img,format=raw,if=ide,index=0 \
		-serial file:/tmp/pinecore-serial.log -display cocoa -m 32

run-doom: flat
	qemu-system-i386 -kernel $(KERNEL_PURE) \
		-drive file=pinecore-doom.img,format=raw,if=ide,index=0 \
		-serial file:/tmp/pinecore-serial.log -display cocoa -m 32

# Launch QEMU paused waiting for GDB attach.
# In another terminal: i686-elf-gdb kernel.pure.bin
#                      (gdb) target remote :1234
#                      (gdb) continue
# Set breakpoints on PM client EIPs by adding the LDT[16] base of the
# active client. PM samples in the serial log give you the EIP range.
run-pure-gdb: flat
	qemu-system-i386 -kernel $(KERNEL_PURE) \
		-drive file=pinecore-pure-hdd.img,format=raw,if=ide,index=0 \
		-serial file:/tmp/pinecore-serial.log -display cocoa -m 32 \
		-s -S

# Same but no display — useful when you want to drive everything from gdb.
run-pure-gdb-headless: flat
	qemu-system-i386 -kernel $(KERNEL_PURE) \
		-drive file=pinecore-pure-hdd.img,format=raw,if=ide,index=0 \
		-serial file:/tmp/pinecore-serial.log -display none -m 32 \
		-s -S

# DOOM disk + paused for gdb. In another terminal:
#   i686-elf-gdb kernel.pure.bin
#   (gdb) target remote :1234
#   (gdb) break v86_gpf_handler
#   (gdb) condition <n> ((struct v86_frame *)frame)->cs == 0x276F
#   (gdb) continue
run-doom-gdb: flat
	qemu-system-i386 -kernel $(KERNEL_PURE) \
		-drive file=pinecore-doom.img,format=raw,if=ide,index=0 \
		-serial file:/tmp/pinecore-serial.log -display cocoa -m 32 \
		-s -S

# ================================================================
# Kernel modules (.kmd files — loadable ELF32 relocatable objects).
# Built with the same i686-elf-gcc as the kernel; just left as .o
# (renamed to .kmd) so the kernel's module loader can ingest them.
# Image builder stages these into /DRIVERS/ on the FAT partition.
# ================================================================
MODULES_DIR = modules
MODULE_SRCS = $(MODULES_DIR)/hello.c \
              $(MODULES_DIR)/r6040.c \
              $(MODULES_DIR)/null.c \
              $(MODULES_DIR)/loopback.c \
              $(MODULES_DIR)/usbcore.c \
              $(MODULES_DIR)/uhci.c \
              $(MODULES_DIR)/ohci.c \
              $(MODULES_DIR)/hid.c \
              $(MODULES_DIR)/iwi.c
MODULE_BINS = $(MODULE_SRCS:%.c=%.kmd)
MODULE_CFLAGS = -march=i386 -ffreestanding -nostdlib -fno-common -fno-builtin \
                -fno-pic -m32 -Os -Wall -Wextra -Iinclude

$(MODULES_DIR)/%.kmd: $(MODULES_DIR)/%.c
	$(CC) $(MODULE_CFLAGS) -c $< -o $@

modules: $(MODULE_BINS)
	@echo "Modules built: $(MODULE_BINS)"

# ================================================================
# Native boot system (PCBOOT)
# Builds MBR + VBR + PCBOOT.SYS, then a pure USB image with no
# FreeDOS in the chain. Target hardware: Vortex86SX + any PC.
# ================================================================
PCBOOT_DIR    = boot/pcboot
MBR_BIN       = $(PCBOOT_DIR)/mbr.bin
VBR_BIN       = $(PCBOOT_DIR)/vbr.bin
VBR_FLOPPY_BIN= $(PCBOOT_DIR)/vbr_floppy.bin
PCBOOT_BIN    = $(PCBOOT_DIR)/pcboot.bin
PURE_USB      = pinecore-pure-usb.img
PURE_FLOPPY   = pinecore-pure-floppy.img

$(MBR_BIN): $(PCBOOT_DIR)/mbr.asm
	nasm -f bin -o $@ $<

$(VBR_BIN): $(PCBOOT_DIR)/vbr.asm
	nasm -f bin -o $@ $<

$(VBR_FLOPPY_BIN): $(PCBOOT_DIR)/vbr_floppy.asm
	nasm -f bin -o $@ $<

$(PCBOOT_BIN): $(PCBOOT_DIR)/pcboot.asm
	nasm -f bin -o $@ $<

pcboot-bins: $(MBR_BIN) $(VBR_BIN) $(VBR_FLOPPY_BIN) $(PCBOOT_BIN)
	@echo "Boot binaries built: $(MBR_BIN), $(VBR_BIN), $(VBR_FLOPPY_BIN), $(PCBOOT_BIN)"

# Image builder: lays MBR/VBR/PCBOOT.SYS + KERNEL.BIN onto a 64 MB raw image,
# then mirrors all apps (DOOM, EDIT, DESKTOP, COMMAND.COM, etc.) from the
# working pinecore-pure-hdd.img.
$(PURE_USB): pcboot-bins $(KERNEL_PURE) flat modules
	../tools/build-pure-usb.py \
	    --mbr $(MBR_BIN) \
	    --vbr $(VBR_BIN) \
	    --pcboot $(PCBOOT_BIN) \
	    --kernel kernel.pure.flat \
	    --from-image pinecore-pure-hdd.img \
	    --modules-dir $(MODULES_DIR) \
	    --out $@

pure-usb: $(PURE_USB)
	@echo "=== Pure USB image built: $(PURE_USB) ==="
	@ls -la $(PURE_USB)

# Boot the pure USB image in QEMU (no -kernel flag — pure native chain)
run-pure-usb: pure-usb
	qemu-system-i386 \
	    -drive file=$(PURE_USB),format=raw,if=ide,index=0 \
	    -serial file:/tmp/pinecore-serial.log -display cocoa -m 32 -boot c

# Same but headless for scripted testing
run-pure-usb-headless: pure-usb
	qemu-system-i386 \
	    -drive file=$(PURE_USB),format=raw,if=ide,index=0 \
	    -serial file:/tmp/pinecore-serial.log -display none -m 32 -boot c

# ================================================================
# Clean
# ================================================================
clean:
	rm -rf build/
	rm -f $(KERNEL_DOS) $(KERNEL_PURE) kernel.dos.flat kernel.pure.flat kernel.flat
	rm -f $(MBR_BIN) $(VBR_BIN) $(PCBOOT_BIN) $(PURE_USB)
	rm -f $(MODULE_BINS)

.PHONY: all flat flat-compat run-dos run-pure run-pure-gdb run-pure-gdb-headless run-doom run-doom-gdb \
        pcboot-bins pure-usb run-pure-usb run-pure-usb-headless modules clean
